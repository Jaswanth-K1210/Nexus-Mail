# ============================================
# NEXUS MAIL — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- App ---
APP_NAME=NexusMail
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-min-32-chars-here
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=nexus_mail

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Google Calendar ---
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly,https://www.googleapis.com/auth/calendar.events
CALENDAR_API_VERSION=v3
CALENDAR_BUSINESS_HOURS_START=9
CALENDAR_BUSINESS_HOURS_END=18

# --- AI Providers ---
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key-optional
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# --- Meeting Intelligence ---
MEETING_DETECTION_CONFIDENCE_THRESHOLD=0.75
SUGGESTED_SLOTS_COUNT=3

# --- Notification ---
NOTIFICATION_POLL_INTERVAL_SECONDS=60

# --- Security ---
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ENCRYPTION_KEY=your-aes-256-encryption-key-base64

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,chrome-extension://your-extension-id
